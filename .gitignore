# ============================================================
# .gitignore for XMR RIG Project
# ============================================================

# Arduino / ESP32
*.ino.pre
*.o
*.d
*.elf
*.hex
*.eep
*.lst
*.sym
*.lss
*.map
*.tmp
*.build/
*.pioenvs/
*.piolibdeps/

# Compiled binaries
*.exe
*.out
*.app
*.dll
*.so
*.dylib
*.bin

# Build directories
/build/
/dist/
/tmp/
/out/
/release/
/debug/

# IDE files
.DS_Store
Thumbs.db
*.swp
*.swo
*~
.idea/
.vscode/
.vs/
*.suo
*.user

# PlatformIO
.pio/
lib_deps/

# Environment variables
.env
.env.local
secrets.h
config.h

# Logs
*.log
logs/

# Wallet/Private keys
*.wallet
*.key
*.priv
*.pem
*.crt

# Large files
*.zip
*.tar.gz
*.rar
*.7z
*.iso
*.img

# Temporary files
*.bak
*.old
*.orig

# Keep essential files
!index.html
!README.md
!rig.cpp
!*.ino

# Keep docs
!docs/
!*.md
!LICENSE
